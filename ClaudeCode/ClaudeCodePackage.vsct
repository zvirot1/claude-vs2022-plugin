<?xml version="1.0" encoding="utf-8"?>
<CommandTable xmlns="http://schemas.microsoft.com/VisualStudio/2005-10-18/CommandTable"
              xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <Extern href="stdidcmd.h"/>
  <Extern href="vsshlids.h"/>

  <Commands package="guidClaudeCodePackage">

    <Groups>
      <!-- Main menu group under Tools -->
      <Group guid="guidClaudeCodeCmdSet" id="ClaudeMenuGroup" priority="0x0600">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_MENU_TOOLS"/>
      </Group>
      <!-- Editor context menu group -->
      <Group guid="guidClaudeCodeCmdSet" id="ClaudeEditorContextGroup" priority="0x0800">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_CTXT_CODEWIN"/>
      </Group>
    </Groups>

    <Buttons>
      <!-- Open Claude Chat -->
      <Button guid="guidClaudeCodeCmdSet" id="cmdidOpenClaude" priority="0x0100" type="Button">
        <Parent guid="guidClaudeCodeCmdSet" id="ClaudeMenuGroup"/>
        <Strings>
          <ButtonText>Open Claude Chat</ButtonText>
        </Strings>
      </Button>

      <!-- New Session -->
      <Button guid="guidClaudeCodeCmdSet" id="cmdidNewSession" priority="0x0110" type="Button">
        <Parent guid="guidClaudeCodeCmdSet" id="ClaudeMenuGroup"/>
        <Strings>
          <ButtonText>New Conversation</ButtonText>
        </Strings>
      </Button>

      <!-- Send Selection -->
      <Button guid="guidClaudeCodeCmdSet" id="cmdidSendSelection" priority="0x0200" type="Button">
        <Parent guid="guidClaudeCodeCmdSet" id="ClaudeEditorContextGroup"/>
        <Strings>
          <ButtonText>Send Selection to Claude</ButtonText>
        </Strings>
      </Button>

      <!-- Explain Code -->
      <Button guid="guidClaudeCodeCmdSet" id="cmdidExplainCode" priority="0x0210" type="Button">
        <Parent guid="guidClaudeCodeCmdSet" id="ClaudeEditorContextGroup"/>
        <Strings>
          <ButtonText>Explain Code</ButtonText>
        </Strings>
      </Button>

      <!-- Review Code -->
      <Button guid="guidClaudeCodeCmdSet" id="cmdidReviewCode" priority="0x0220" type="Button">
        <Parent guid="guidClaudeCodeCmdSet" id="ClaudeEditorContextGroup"/>
        <Strings>
          <ButtonText>Review Code</ButtonText>
        </Strings>
      </Button>

      <!-- Refactor Code -->
      <Button guid="guidClaudeCodeCmdSet" id="cmdidRefactorCode" priority="0x0230" type="Button">
        <Parent guid="guidClaudeCodeCmdSet" id="ClaudeEditorContextGroup"/>
        <Strings>
          <ButtonText>Refactor Code</ButtonText>
        </Strings>
      </Button>

      <!-- Analyze File -->
      <Button guid="guidClaudeCodeCmdSet" id="cmdidAnalyzeFile" priority="0x0240" type="Button">
        <Parent guid="guidClaudeCodeCmdSet" id="ClaudeEditorContextGroup"/>
        <Strings>
          <ButtonText>Analyze This File</ButtonText>
        </Strings>
      </Button>

      <!-- Focus Toggle (global) -->
      <Button guid="guidClaudeCodeCmdSet" id="cmdidFocusToggle" priority="0x0300" type="Button">
        <Parent guid="guidClaudeCodeCmdSet" id="ClaudeMenuGroup"/>
        <Strings>
          <ButtonText>Toggle Claude Focus</ButtonText>
        </Strings>
      </Button>

      <!-- Insert @-mention (Alt+K) -->
      <Button guid="guidClaudeCodeCmdSet" id="cmdidInsertAtMention" priority="0x0400" type="Button">
        <Parent guid="guidClaudeCodeCmdSet" id="ClaudeEditorContextGroup"/>
        <Strings>
          <ButtonText>Insert @-Mention to Claude</ButtonText>
        </Strings>
      </Button>
    </Buttons>
  </Commands>

  <KeyBindings>
    <!-- Use Ctrl+Alt combos to avoid clashes with VS defaults:
         - Ctrl+Shift+C is Class View
         - Ctrl+Shift+S is Save All
         - Ctrl+Shift+R is Record Macro
         Ctrl+Alt+C/S/R/F are mostly free. -->
    <KeyBinding guid="guidClaudeCodeCmdSet" id="cmdidOpenClaude"
                editor="guidVSStd97" key1="C" mod1="Control Alt"/>
    <KeyBinding guid="guidClaudeCodeCmdSet" id="cmdidSendSelection"
                editor="guidVSStd97" key1="S" mod1="Control Alt"/>
    <KeyBinding guid="guidClaudeCodeCmdSet" id="cmdidRefactorCode"
                editor="guidVSStd97" key1="R" mod1="Control Alt"/>
    <KeyBinding guid="guidClaudeCodeCmdSet" id="cmdidFocusToggle"
                editor="guidVSStd97" key1="VK_ESCAPE" mod1="Control"/>
    <!-- Alt+K = Insert @-mention into Claude (matches IntelliJ + VSCode plugins) -->
    <KeyBinding guid="guidClaudeCodeCmdSet" id="cmdidInsertAtMention"
                editor="guidVSStd97" key1="K" mod1="Alt"/>
  </KeyBindings>

  <Symbols>
    <GuidSymbol name="guidClaudeCodePackage" value="{B1C2D3E4-F5A6-7890-BCDE-F12345678901}" />
    <GuidSymbol name="guidClaudeCodeCmdSet" value="{D2E3F4A5-B6C7-8901-DEF0-234567890123}">
      <IDSymbol name="ClaudeMenuGroup" value="0x1020"/>
      <IDSymbol name="ClaudeEditorContextGroup" value="0x1021"/>
      <IDSymbol name="cmdidOpenClaude" value="0x0100"/>
      <IDSymbol name="cmdidNewSession" value="0x0110"/>
      <IDSymbol name="cmdidSendSelection" value="0x0200"/>
      <IDSymbol name="cmdidExplainCode" value="0x0210"/>
      <IDSymbol name="cmdidReviewCode" value="0x0220"/>
      <IDSymbol name="cmdidRefactorCode" value="0x0230"/>
      <IDSymbol name="cmdidAnalyzeFile" value="0x0240"/>
      <IDSymbol name="cmdidFocusToggle" value="0x0300"/>
      <IDSymbol name="cmdidInsertAtMention" value="0x0400"/>
    </GuidSymbol>
  </Symbols>

</CommandTable>
